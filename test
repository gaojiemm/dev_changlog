name: JST定期実行テスト

on:
  schedule:
    # 毎日 日本時間 17:00 (JST) に実行
    # cron: '分 時 日 月 曜日'
    - cron: '0 17 * * *'
      timezone: Asia/Tokyo
  workflow_dispatch: # 手動実行用ボタン（テスト用）

jobs:
  test-job:
    name: 実行ログの確認
    runs-on: ubuntu-latest
    steps:
      - name: 現在時刻を表示する
        run: |
          echo "-------- 実行情報 --------"
          echo "JST時刻: $(TZ='Asia/Tokyo' date)"
          echo "UTC時刻: $(date -u)"
          echo "トリガー: ${{ github.event_name }}"
          echo "--------------------------"

      - name: 日本語のステップ
        run: echo "定期実行のテストに成功しました。"
