name: Test Schedule JST

on:
  schedule:
    # 建议设置一个离现在最近的时间点进行测试
    # 比如现在是 16:30，你可以设置为 16:45
    - cron: '45 16 * * *'
      timezone: Asia/Tokyo
  workflow_dispatch: # 保留手动按钮，方便对比日志

jobs:
  test-log:
    runs-on: ubuntu-latest
    steps:
      - name: Display Current Time
        run: |
          echo "Workflow 触发时间 (UTC): $(date -u)"
          echo "Workflow 触发时间 (Local): $(date)"
          echo "触发事件名称: ${{ github.event_name }}"
